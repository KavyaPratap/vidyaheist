
rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Use lowercase for robust comparison
      return isUserAuthenticated() && request.auth.token.email.lower() == 'vidyaheist@gmail.com';
    }
 
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow create, update: if isOwner(userId);
    }

    match /testSeries/{seriesId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /tests/{testId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();

        match /questions/{questionId} {
          allow read: if true;
          allow create, update, delete: if isAdmin();
        }
      }
    }

    match /purchases/{purchaseId} {
      // Users can read their own orders, Admin can read all
      allow read: if isUserAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only users can create their own orders
      allow create: if isUserAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admin can update order status (verify/reject)
      allow update: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isUserAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isUserAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
