
rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
 
    match /users/{userId} {
      // Users can read any profile if authenticated
      allow read: if isUserAuthenticated();
      // Users can only create or update their own profile
      allow create, update: if isOwner(userId);
    }

    match /testSeries/{seriesId} {
      // Anyone can view the test series in the store
      allow read: if true;

      // Any authenticated user can create a series, and they become the owner.
      // Client-side code should restrict this to admins only.
      allow create: if isUserAuthenticated() && request.resource.data.createdBy == request.auth.uid;

      // Only the original creator (admin) can update or delete it.
      allow update, delete: if isUserAuthenticated() && get(/databases/$(database)/documents/testSeries/$(seriesId)).data.createdBy == request.auth.uid;

      match /questions/{questionId} {
        // Anyone can read the questions for a test.
        allow read: if true;

        // Only the series owner (admin) can write questions.
        allow create, update, delete: if isUserAuthenticated() && get(/databases/$(database)/documents/testSeries/$(seriesId)).data.createdBy == request.auth.uid;
      }
    }
  }
}
