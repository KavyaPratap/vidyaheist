
{
    "entities": {
        "user": {
            "title": "User",
            "description": "A user of the application.",
            "type": "object",
            "properties": {
                "uid": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "displayName": { "type": "string" },
                "photoURL": { "type": "string", "format": "uri" },
                "mobileNumber": { "type": "string" }
            },
            "required": ["uid", "email"]
        },
        "testSeries": {
            "title": "Test Series",
            "description": "A collection of mock tests (Course).",
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "number" },
                "subject": { "type": "string" },
                "imageUrl": { "type": "string", "description": "Banner image URL" },
                "createdAt": { "type": "string", "format": "date-time" }
            }
        },
        "test": {
            "title": "Test",
            "description": "A specific mock exam within a series.",
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "duration": { "type": "number", "description": "Duration in minutes" },
                "order": { "type": "number", "description": "Position in the list" },
                "createdAt": { "type": "string", "format": "date-time" }
            }
        },
        "booking": {
            "title": "Booking",
            "description": "A counselling session booking.",
            "type": "object",
            "properties": {
                "userId": { "type": "string" },
                "type": { "type": "string", "enum": ["JoSAA", "IAT-NEST", "MHTCET"] },
                "slotTime": { "type": "string", "format": "date-time" },
                "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] }
            }
        },
        "purchase": {
            "title": "Purchase",
            "description": "A record of a course purchase.",
            "type": "object",
            "properties": {
                "userId": { "type": "string" },
                "seriesId": { "type": "string" },
                "status": { "type": "string", "enum": ["pending", "verified", "rejected"] }
            }
        }
    },
    "auth": {
        "providers": ["email-password", "google.com"]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": { "$ref": "#/entities/user" },
            "description": "User profile information."
        },
        "/testSeries/{seriesId}": {
            "schema": { "$ref": "#/entities/testSeries" },
            "description": "Course/Series data."
        },
        "/testSeries/{seriesId}/tests/{testId}": {
            "schema": { "$ref": "#/entities/test" },
            "description": "Individual tests within a series."
        },
        "/testSeries/{seriesId}/tests/{testId}/questions/{questionId}": {
            "schema": "object",
            "description": "Questions within a specific test."
        },
        "/bookings/{bookingId}": {
            "schema": { "$ref": "#/entities/booking" },
            "description": "Counselling bookings."
        },
        "/purchases/{purchaseId}": {
            "schema": { "$ref": "#/entities/purchase" },
            "description": "Course purchases."
        }
    }
}
